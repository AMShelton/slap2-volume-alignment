   "source": [
    "\n",
    "raw_z = SELECTED_Z_FOR_RAW_CHECK\n",
    "output_ch_key = f\"channel_{ALIGNMENT_CHANNEL + 1}\"\n",
    "output_path = output_paths[output_ch_key]\n",
    "\n",
    "with tifffile.TiffFile(INPUT_TIF) as raw_tif:\n",
